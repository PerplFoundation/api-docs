# Perpl API Configuration
# Copy this file to .env and update values as needed

# ===================
# API URLs (Mainnet by default)
# ===================
PERPL_API_URL=https://app.perpl.xyz/api
PERPL_WS_URL=wss://app.perpl.xyz

# Testnet:
# PERPL_API_URL=https://testnet.perpl.xyz/api
# PERPL_WS_URL=wss://testnet.perpl.xyz

# ===================
# Chain Configuration
# ===================
# Mainnet: 143
# Testnet: 10143
PERPL_CHAIN_ID=143

# RPC URL (for on-chain operations)
PERPL_RPC_URL=https://rpc.monad.xyz
# Testnet: https://testnet-rpc.monad.xyz

# ===================
# Contract Addresses (Mainnet)
# ===================
PERPL_EXCHANGE_ADDRESS=0x34B6552d57a35a1D042CcAe1951BD1C370112a6F
PERPL_COLLATERAL_TOKEN=0x00000000eFE302BEAA2b3e6e1b18d08D69a9012a

# Testnet:
# PERPL_EXCHANGE_ADDRESS=0x1964c32f0be608e7d29302aff5e61268e72080cc
# PERPL_COLLATERAL_TOKEN=0xdf5b718d8fcc173335185a2a1513ee8151e3c027

# ===================
# Authentication (API keys)
# ===================
# Create a key at the web UI (app.perpl.xyz/apikeys, testnet.perpl.xyz/apikeys)
# or enroll one programmatically — see authentication.md.
#
# The example programs reuse an already-enrolled key when both of these are set;
# otherwise they enroll a fresh key (using the wallet key below) and print these
# two values for you to export. Never commit real secrets.
# PERPL_API_KEY=            # the opaque X-API-Key token from enrollment
# PERPL_API_KEY_SECRET=     # hex of the 32-byte Ed25519 private key
#
# Wallet private key used only to authorize (sign) enrollment (testing only!):
# OWNER_PRIVATE_KEY=0x...

# ===================
# Market IDs
# ===================
# Mainnet: BTC=1, MON=10, ETH=20, SOL=30
# Testnet: BTC=16, ETH=32, SOL=48, MON=64, ZEC=256
